<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SindhiKeyboard_new" parent="Theme.MaterialComponents.Light">
        <!-- Primary brand color. -->
        <item name="android:splitMotionEvents">false</item>
        <item name="android:windowEnableSplitTouch">false</item>
        <item name="colorPrimary">@color/maroon_500</item>
        <item name="colorPrimaryVariant">@color/maroon_200</item>
        <item name="colorOnPrimary">@color/White</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.SindhiKeyboard_new.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.SindhiKeyboard_new.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.SindhiKeyboard_new.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
    <style name="text_regular">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:gravity">start</item>
        <item name="android:fontFamily">@font/lexend_semibold</item>
        <item name="android:includeFontPadding">false</item>
    </style>
    <style name="text_bold" parent="text_regular">
        <item name="android:fontFamily">@font/lemonada_bold</item>
    </style>
    <style name="text_bold_12" parent="text_bold">
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>
    <style name="text_regular_12" parent="text_regular">
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>
    <style name="text_bold_16" parent="text_bold">
        <item name="android:textSize">@dimen/_16ssp</item>
    </style>
</resources>